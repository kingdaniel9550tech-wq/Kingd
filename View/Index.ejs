<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Feed</title>
<style>body{margin:0;background:#0f172a;color:#e2e8f0;font-family:system-ui;padding:20px}
.card{background:#1e293b;padding:24px;border-radius:16px;width:min(700px,100%);margin:0 auto}input,textarea,button{width:100%;padding:12px;margin-top:8px;border-radius:10px;border:1px solid #334155;background:#0b1220;color:#e2e8f0}
button{background:#38bdf8;color:#0b1220;border:0;font-weight:700;cursor:pointer}.post{background:#0b1220;padding:16px;border-radius:12px;margin-top:14px}
.post img{max-width:100%;border-radius:10px;margin-top:10px}.row{display:flex;justify-content:space-between;align-items:center}small{color:#94a3b8}</style></head>
<body><div class="card">
<div class="row"><h2>Hi, <%= user %></h2><div style="display:flex;gap:8px"><% if(isAdmin){ %><a href="/admin"><button style="width:auto;background:#a855f7">Admin</button></a><% } %><a href="/logout"><button style="width:auto;background:#ef4444">Logout</button></a></div></div>

<% if(isAdmin){ %><hr><h3>New Post</h3><form method="POST" action="/post" enctype="multipart/form-data">
<textarea name="text" rows="3" placeholder="Write something..."></textarea><input type="file" name="image" accept="image/*"><button>Post</button></form><hr><% } %>

<h3>Feed</h3><% if(!posts.length){ %><p style="color:#94a3b8">No posts yet.</p><% } %>
<% posts.forEach(p=>{ %><div class="post">
<small><%= new Date(p.created_at).toLocaleString() %> • by <b><%= p.username %></b></small>
<% if(p.text){ %><p style="white-space:pre-wrap;margin:8px 0"><%= p.text %></p><% } %>
<% if(p.image){ %><img src="<%= p.image %>" loading="lazy"><% } %>
<% if(isAdmin){ %><form method="POST" action="/delete/<%= p.id %>"><button>Delete</button></form><% } %></div><% }) %></div></body></html>
